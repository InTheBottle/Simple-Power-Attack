#include <winresrc.h>

VS_VERSION_INFO VERSIONINFO
FILEVERSION @PLUGIN_VERSION_MAJOR@, @PLUGIN_VERSION_MINOR@, @PLUGIN_VERSION_PATCH@, 0
PRODUCTVERSION @PLUGIN_VERSION_MAJOR@, @PLUGIN_VERSION_MINOR@, @PLUGIN_VERSION_PATCH@, 0
FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
FILEFLAGS 0
FILEOS VOS_NT_WINDOWS32
FILETYPE VFT_DLL
FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "FileDescription", "@PLUGIN_DESCRIPTION@"
            VALUE "FileVersion", "@PLUGIN_VERSION@.0"
            VALUE "InternalName", "@PLUGIN_NAME@"
            VALUE "LegalCopyright", ""
            VALUE "OriginalFilename", "@PLUGIN_NAME@.dll"
            VALUE "ProductName", "@PLUGIN_NAME@"
            VALUE "ProductVersion", "@PLUGIN_VERSION@.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END
